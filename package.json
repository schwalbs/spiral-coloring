{
  "name": "sprial-coloring",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "colors:dharma": "npm run colors -- dharma",
    "colors:pro-chem": "npm run colors -- pro-chem",
    "colors:jacquard": "npm run colors -- jacquard",
    "colors": "node ./scripts/build-colors.js",
    "build:clean": "rm -rf dist/",
    "build:pwa-assets": "pwa-assets-generator",
    "prebuild": "npm run build:clean",
    "build": "tsc -b && vite build",
    "predeploy": "concurrently --names pwa-assets,build,colors -c blue,green,magenta \"npm run build:pwa-assets\" \"npm run build\" \"npm run colors\"",
    "deploy": "gh-pages -d dist",
    "lint": "eslint . --fix",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": "prettier --write"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "bootstrap": "^5.3.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "@babel/core": "^7.29.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "canvas": "^3.2.3",
    "chalk": "^5.6.2",
    "color-sorter": "^8.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "node-html-parser": "^7.1.0",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  },
  "allowScripts": {
    "canvas@3.2.3": true,
    "sharp@0.33.5": true
  }
}
